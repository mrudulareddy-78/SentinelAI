{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Sentinel",
    "Audience": "SentinelClients",
    "SigningKey": "SentinelJwtSigningKey-1234567890",
    "TokenLifetimeMinutes": 60
  },
  "Aes": {
    "KeyMaterial": "SentinelAES256Key-1234567890ABCD",
    "EncryptedHeaderName": "X-Encrypted",
    "IvHeaderName": "X-Init-Vector"
  },
  "ReverseProxy": {
    "Routes": {
      "default-route": {
        "ClusterId": "jsonplaceholder-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "jsonplaceholder-cluster": {
        "Destinations": {
          "jsonplaceholder-destination": {
            "Address": "https://jsonplaceholder.typicode.com/"
          }
        }
      }
    }
  }
}
